# Canvas Medical OAuth Credentials
# ─────────────────────────────────────────────────────────────
# HOW TO USE THIS FILE:
#   1. Copy this file to:  ~/.canvas/credentials.ini
#      (The ~/.canvas/ folder may not exist yet — Claude will create it for you)
#   2. Replace YOUR-SANDBOX-NAME with your actual Canvas subdomain
#   3. Replace the placeholder values with your real credentials
#      (you got these from Canvas sandbox → Settings → OAuth Applications)
#   4. NEVER commit the filled-in version to git — it contains your secret key
#
# CRITICAL — SECTION NAME:
#   The name in brackets [like-this] must be the SUBDOMAIN of your Canvas URL.
#   Example: if your sandbox URL is https://suvida-dev.canvasmedical.com
#            then write:  [suvida-dev]
#   If this name is wrong, ALL commands will fail with a 404 error.
#
# WHERE TO GET YOUR VALUES:
#   client_id      → Canvas sandbox → Settings → OAuth Apps → your app → "Client ID"
#   client_secret  → Same page → "Client Secret" (shown once — copy it immediately)
# ─────────────────────────────────────────────────────────────

[YOUR-SANDBOX-NAME]
client_id = PASTE_YOUR_CLIENT_ID_HERE
client_secret = PASTE_YOUR_CLIENT_SECRET_HERE
is_default = true
