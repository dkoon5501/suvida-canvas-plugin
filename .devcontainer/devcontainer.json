{
  "name": "Suvida Canvas Plugin",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",

  "postCreateCommand": "pip install -r setup/requirements.txt pytest && mkdir -p ~/.canvas",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.pylance",
        "ms-python.debugpy"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.testing.pytestEnabled": true,
        "python.testing.pytestArgs": ["tests/"]
      }
    }
  },

  "remoteEnv": {
    "PYTHONPATH": "${containerWorkspaceFolder}/plugins"
  }
}
